---
import Footer from "../components/Footer.astro";
import Header from "../components/Header.astro";
import BaseLayout from "./BaseLayout.astro";
import { format } from "date-fns";
export interface Props {
  content: {
    title: string;
    description?: string;
    pubDate: string;
    readingTime?: string;
    coverImage?: string;
  };
}

const {
  content: { title, pubDate, readingTime },
} = Astro.props;
---

<BaseLayout title={title}>
  <Header />
  <main>
    <div class="mx-auto max-w-3xl px-4 md:px-6 py-16">
      <article class="prose prose-invert max-w-none">
        <h1>{title}</h1>
        <p>
          <span>{format(new Date(pubDate), "MMM dd, yyyy")}</span>
          <span>•</span>
          <span>{readingTime}</span>
        </p>
        <hr />
        <slot />
      </article>
    </div>
  </main>
  <Footer />
</BaseLayout>

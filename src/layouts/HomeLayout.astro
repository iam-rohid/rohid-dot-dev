---
import Footer from "../components/Footer.astro";
import BaseLayout from "./BaseLayout.astro";

export interface Props {
  title: string;
}

const { title } = Astro.props;
---

<BaseLayout title={title}>
  <header class="bg-gray-900">
    <div class="mx-auto max-w-6xl px-4 md:px-6">
      <div class="h-16 flex items-center gap-4 md:gap-6">
        <nav class="flex-1">
          <ul class="flex items-center gap-4 md:gap-6">
            <li>
              <a class="hover:text-gray-50" href="/blog">Blog</a>
            </li>
            <li>
              <a class="hover:text-gray-50" href="/store">Store</a>
            </li>
            <li>
              <a class="hover:text-gray-50" href="/contact">Contact</a>
            </li>
          </ul>
        </nav>
        <ul class="flex items-center gap-4 md:gap-6 h-full">
          <li>
            <a href="https://twitter.com" class="hover:text-gray-50 text-xl">
              <i class="fa-brands fa-instagram"></i>
            </a>
          </li>
          <li>
            <a href="https://twitter.com" class="hover:text-gray-50 text-xl">
              <i class="fa-brands fa-twitter"></i>
            </a>
          </li>
        </ul>
      </div>
      <div class="text-center py-16">
        <h1 class="text-5xl font-bold mb-4 text-gray-50">Rohid</h1>
        <p class="text-xl">Self-thought Software Developer</p>
      </div>
    </div>
  </header>
  <slot />
  <Footer />
</BaseLayout>

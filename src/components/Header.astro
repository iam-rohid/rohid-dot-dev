---
interface Props {
  hideName?: boolean;
}
const { hideName } = Astro.props;
---

<header class="bg-white dark:bg-gray-900 sticky top-0 z-20">
  <div
    class="h-16 flex items-center gap-4 md:gap-6 mx-auto max-w-6xl px-4 md:px-6"
  >
    {
      !hideName && (
        <a
          class="dark:hover:text-gray-50 hover:text-gray-900 text-xl font-semibold"
          href="/"
        >
          Rohid
        </a>
      )
    }

    <nav class="flex-1">
      <ul class="flex items-center gap-4 md:gap-6">
        <li>
          <a class="hover:text-gray-900 dark:hover:text-gray-50" href="/blog"
            >Blog</a
          >
        </li>
        <li>
          <a
            class="hover:text-gray-900 dark:hover:text-gray-50"
            href="mailto:rohidul209@gmail.com?subject=Contact with Rohid"
            >Contact</a
          >
        </li>
      </ul>
    </nav>

    <ul class="flex items-center gap-4 md:gap-6 h-full">
      <li>
        <a
          href="https://twitter.com/rohid_dev"
          class="hover:text-gray-900 dark:hover:text-gray-50 text-xl"
        >
          <i class="fa-brands fa-twitter"></i>
        </a>
      </li>
    </ul>
  </div>
</header>

---
import type { ProjectFrontmatter } from "@utilities/types/project-frontmatter";

interface Props {
  project: ProjectFrontmatter;
  url: string;
}

const {
  project: { title, description, coverPhoto },
  url,
} = Astro.props;
---

<article>
  <a href={url}>
    <img
      src={coverPhoto}
      alt={`${title} icon`}
      class="w-full aspect-[3/2] rounded-2xl object-cover my-6"
    />
    <h3 class="text-2xl font-semibold text-gray-900 dark:text-gray-50 my-6">
      {title}
    </h3>
    <p class="my-4 line-clamp-3">{description}</p>
  </a>
</article>

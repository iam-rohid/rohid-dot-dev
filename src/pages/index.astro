---
import ArticleCard from "@/components/ArticleCard.astro";
import HomeLayout from "@/layouts/HomeLayout.astro";
import type { ArticleFrontmatter } from "@/types/article-frontmatter";

const posts = await Astro.glob<ArticleFrontmatter>("./blog/*.mdx");
const filteredPosts = posts.filter((post) => !post.frontmatter.draft);
---

<HomeLayout title="Rohid - Home">
  <main>
    <div class="mx-auto max-w-6xl px-4 md:px-6 py-12 space-y-12">
      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6 md:gap-8">
        {
          filteredPosts.map((item) => (
            <ArticleCard
              url={item.url}
              title={item.frontmatter.title}
              description={item.frontmatter.description}
              pubDate={item.frontmatter.pubDate}
              readingTime={item.frontmatter.readingTime}
            />
          ))
        }
      </div>
    </div>
  </main>
</HomeLayout>
